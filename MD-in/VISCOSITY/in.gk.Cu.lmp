######基本模拟规则设置#########
units metal
dimension 3
boundary p p p
atom_style atomic
#######定义几何模型##########
#使用LAMMPS内部命令建立模型需要三个命令联用：region命令，create_box命令和create_atoms命令
region box block -90 90 -90 90 -90 90 units box
create_box 2 box
lattice fcc 5.10873
create_atoms 2 region box
region sphere_cu sphere 0.0 0.0 0.0 45 units box side in
region intersect_temp intersect 2 box sphere_cu
region intersect_temp delete
region sphere sphere 0.0 0.0 0.0 45 units box side in
lattice fcc 3.615
create_atoms 1 region sphere
#region wat union 2 box 1 intersect_temp
########定义物理模型##############
neighbor 2.0 bin
neigh_modify delay 0 every 1 check yes
pair_style hybrid sw eam lj/cut 10 #混合势函数
pair_coeff * * sw mW.sw NULL mW
pair_coeff 1 1 eam Cu_u6.eam
pair_coeff 1 2 lj/cut 0.006 3.0 #水和铜的参数，可以通过一些实验参数进行调节
mass      1 63.546
mass      2 18.0154
write_data pre.data
#replicate 5 5 5 #利用复制命令建立更大的模型，具体模型多大需要经验。具体可以跑一下算例
#write_data pre5.data
#run 1
#######定义分组信息#########
group cu type 1
group wat type 2
#######弛豫部分#######
#MM
minimize 0.0 1.0e-5 1000 100000
timestep 0.001
thermo 1000
thermo_style custom step temp etotal press
thermo_modify flush yes
velocity all create 300 3265456 rot yes dist gaussian loop local
dump 1 all custom 10000 dump.lammpstrj id type x ys 
#fix fxnvt move nvt temp 300 300 0.2
fix fxnvt all nvt temp 300 300 0.1
#run 1000000
run 100
write_restart restart.equ
########粘度和热导率计算之Green-Kubo法#########
#variable    p equal 20000     # correlation length
variable    p equal 200
variable    s equal 5      # sample interval
variable    d equal $p*$s   # dump interval
variable    t equal 300
variable    kB equal 1.3806504e-23
variable    A2m equal 1.0e-10
variable    ps2s equal 1.0e-12
variable    bar2pa equal 100000
variable    eV2J equal 1.60218E-19
variable    convert_eta equal ${bar2pa}*${bar2pa}*${A2m}*${A2m}*${A2m}*${ps2s}
#粘度的转换因子，单位换算
variable    convert_kappa equal ${eV2J}*${eV2J}/${ps2s}/${A2m}
#导热系数转换因子，单位换算
reset_timestep 0
compute        myKE all ke/atom
compute        myPE all pe/atom
compute        myStress all stress/atom NULL virial
compute        flux all heat/flux myKE myPE myStress
variable       Jx equal c_flux[1]/vol
variable       Jy equal c_flux[2]/vol
variable       Jz equal c_flux[3]/vol
unfix          fxnvt
fix            1 all nve
fix            JJ all ave/correlate $s $p $d c_flux[1] c_flux[2] c_flux[3] type auto fileprofile.heatflux ave running
variable       scale equal $s*dt/$t/$t/${kB}/vol
variable       k11 equal trap(f_JJ[3])*${scale}*${convert_kappa}
variable       k22 equal trap(f_JJ[4])*${scale}*${convert_kappa}
variable       k33 equal trap(f_JJ[5])*${scale}*${convert_kappa}
 
variable        pxy equal pxy
variable        pxz equal pxz
variable        pyz equal pyz
fix             SS all ave/correlate $s $p $d v_pxy v_pxz v_pyz type auto fileprofile.gk ave running
variable        scale equal $s*dt/$t/${kB}*vol
variable        diagfac equal 2-2/3
variable        vxy equal trap(f_SS[3])*${scale}*${convert_eta}
variable        vxz equal trap(f_SS[5])*${scale}*${convert_eta}
variable        vyz equal trap(f_SS[7])*${scale}*${convert_eta}
 
thermo          $d
thermo_style    custom step temp press pe ke v_k11 v_k22 v_k33 v_vxy v_vxz v_vyz
thermo_modify flush yes
#run            1000000
run            2000