# Created on Sun Jan  9 19:24:44 2022
# @author: 阿磊
echo              screen
units             metal
dimension         3
boundary          p p p
atom_style        full
# 定义几个参数 
variable    T  equal 100                              # 温度为 100 K
variable    A  equal 5.4                              # 晶格常数大概为 5.4 A
variable    DT equal 0.01                             # 积分步长为 10 fs
#读取模型
read_data Ar4000.data
#力场设置
pair_style   lj/cut 10.0                               # LJ 势的截断半径取10 A
pair_coeff   * * 1.032e-2 3.405                        # epsilon 和 sigma
velocity     all create ${T} 12345                     
timestep     ${DT}                                     #时间步长
thermo       1000
thermo_style  custom step temp pe ke etotal density
#简单弛豫
fix 1 all npt temp 100 100 1 iso 1 1 10
run 50000
unfix 1
#粘度计算
reset_timestep  0
variable    dt equal 0.01 
variable    KB equal 8.625e-5              
variable bars2Pa equal 1e5         # 1bar=10^5 Pa  1000bar = 0.1 GPa=10^9 Pa
variable A2m equal 1.0e-10         # 1A=10^-10 m
variable ps2s equal 1.0e-12        # 1ps=10^-12 s
variable ev2J equal 96438.5/6.02214e23 # 1ev=96 kJ/mol =96438.5 J/6.03e23
variable g_mol2kg equal 1.0e-3/6.02214e23 #kg
variable    convert_eta equal ${g_mol2kg}/${ps2s}/${A2m} #这一步的作用是什么？单位因子
#lj单位中
compute mytemp all temp/partial  0 0 1                 #在排除x、y方向速度分量后计算温度
fix fxnvt all nvt temp  100 100 1
fix_modify fxnvt temp mytemp                           #移除速度分量，本质上是在原子速度的“偏压”被移除后计算温度

#通过与动量通量成比例的应力张量的非对角分量来测量响应。
fix MP_v all viscosity 10 x y 20                       #每0.1ps交换一次x方向的动量，动量传递方向是y方向
compute layers_eta all chunk/atom bin/1d y center 0.05 units reduced      #在y方向分20块
fix ave_vx all ave/chunk 20 50 1000 layers_eta vx file MP_vx.txt          #输出的是x方向速度

# equilibration run 

variable  dVx equal (2*f_ave_vx[11][3]-f_ave_vx[1][3]-f_ave_vx[20][3])/2   #速度梯度，（2*中间层11层-最下层1层-最上层20层）/2 取平均值          
thermo    1000
thermo_style  custom step temp pe ke etotal f_MP_v v_dVx               
thermo_modify temp mytemp                                
run    100000
unfix    MP_v

# data gathering run
fix    MP_v all  viscosity 10 x y 20
variable  eta equal -(f_MP_v/(2*((step-100000)*${dt})*lx*lz+1.0e-10))/(v_dVx/(ly/2))*${convert_eta}
#100000与上一步平衡的步数一致；因为是在y方向的速度梯度，所以是lx*lz；分母加1.0e-10，防止第一步时，分母为0；
#v_dVx/(ly/2)为速度梯度；粘度的单位：在相距单位距离的两液层中， 使单位面积液层维持单位速度差所需的切线力。 
#其单位在厘米·克·秒(c·g·s)制中为泊(g·cm -1·s -1)，在SI制中为帕斯卡·秒(Pa·s或kg·m -1·s -1)，1泊=0.1帕·秒。
#处理比较巧妙，无量纲，先不管单位，最后根据粘度单位，直接乘以单位因子
thermo_style  custom step temp pe ke etotal f_MP_v v_dVx v_eta
thermo_modify temp mytemp

run          100000