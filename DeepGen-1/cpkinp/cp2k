#!/bin/bash
#SBATCH -N 1
#SBATCH -o %j.out
#SBATCH -e %j.err

module purge
module load mkl cp2k/2024.3/cpu

# 获取SLURM分配的CPU列表
CPU_LIST=$SLURM_CPU_BIND_LIST

echo "Using CPU cores: ${CPU_LIST}"

for inp_file in *.inp; do
    base_name="${inp_file%.inp}"
    mpirun -np $SLURM_NTASKS \
        --bind-to core \
        --report-bindings \
        cp2k.popt -i "$inp_file" > "${base_name}.out" 2>&1
done
