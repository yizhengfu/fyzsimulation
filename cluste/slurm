# 1.munge源码安装  
wget https://github.com/dun/munge/releases/download/munge-0.5.15/munge-0.5.15.tar.xz  
mkdir -pv /opt/munge  
tar xvJf munge-0.5.15.tar.xz  
cd munge-0.5.15/  
./bootstrap
./configure --prefix=/opt/munge --bindir=/opt/munge/bin --sbindir=/opt/munge/sbin --sysconfdir=/opt/munge/etc --localstatedir=/opt/munge/var --with-runstatedir=/opt/munge/run --libdir=/opt/munge/lib --includedir=/opt/munge/include

make -j && make install  
# 添加环境变量  
cat << \EOF > /etc/profile.d/munge_env.sh   
export PATH="/opt/munge/bin:/opt/munge/sbin:$PATH"  
EOF  
source /etc/profile.d/munge_env.sh  

# 创建用户  
export MUNGEUSER=1120  
groupadd -g $MUNGEUSER munge   
useradd -m -c "MUNGE Uid 'N' Gid Emporium" -d /var/lib/munge -u $MUNGEUSER -g munge -s /sbin/nologin munge   

# 更改文件夹权限  
chown -R munge:munge /opt/munge  
mkdir -pv /opt/munge/run/munge 
chown -R munge:munge /opt/munge/run/munge 

mungekey --verbose 
chmod -R 600 /opt/munge/etc/munge/munge.key   

ln -s /opt/munge/lib/systemd/system/munge.service /etc/systemd/system/munge.service  

chown -R munge:munge /etc/systemd/system/munge.service 

# 启动并设置开机自启  
systemctl enable --now munge  

# 2. 支持Power_Saving_Guide中所述实现省电  
https://www.gnu.org/software/freeipmi/download.html  
wget https://ftp.gnu.org/gnu/freeipmi/freeipmi-1.6.11.tar.gz  
tar zxvf freeipmi-1.6.11.tar.gz   
cd freeipmi-1.6.11/  
yum install libgcrypt-devel texinfo  
mkdir /opt/freeipmi  
./configure --prefix=/opt/freeipmi --exec-prefix=/opt/freeipmi --sysconfdir=/opt/freeipmi/etc --localstatedir=/opt/freeipmi/var   
make -j && make install  
# 环境 
cat << \EOF > /etc/profile.d/freeipmi_env.sh   
export FREEIPMI_HOME=/opt/freeipmi  
export PATH=$FREEIPMI_HOME/sbin:$PATH  
export LD_LIBRARY_PATH=$FREEIPMI_HOME/lib:$LD_LIBRARY_PATHexport LD_LIBRARY_PATH=$FREEIPMI_HOME/lib/pkgconfig:$LD_LIBRARY_PATH  
EOF  

source /etc/profile.d/freeipmi_env.sh   

# 3.编译支持openMPI  
