import os
import pandas as pd
from rdkit import Chem
from rdkit.Chem import Descriptors
from scipy.spatial.distance import pdist, squareform
from scipy.cluster.hierarchy import linkage, fcluster
import networkx as nx
from pyvis.network import Network
import subprocess

def get_reaction_files(root_dir='.'):
    """递归获取当前目录及子目录下所有.reaction文件"""
    reaction_files = []
    for dirpath, _, filenames in os.walk(root_dir):
        for filename in filenames:
            if filename.endswith('.reaction'):
                reaction_files.append(os.path.join(dirpath, filename))
    return reaction_files

def process_reaction_file(filepath, target_smiles=None):
    """处理单个反应文件"""
    try:
        with open(filepath, 'r') as f:
            lines = f.readlines()
    except Exception as e:
        print(f"警告: 读取文件 {filepath} 失败: {str(e)}")
        return

    G = nx.DiGraph()
    intermediate_formulae = {}
    node_colors = {}
    processed_lines = []

    # 处理文件内容
    for line in lines:
        parts = line.strip().split(' ', 1)
        if len(parts) < 2:
            continue

        try:
            frequency = int(parts[0])
            reaction = parts[1]
        except:
            continue

        if '->' in reaction:
            reactant, product = reaction.split('->')
            reactant = reactant.strip()
            product = product.strip()

            # 筛选目标SMILES（可选）
            if target_smiles:
                if target_smiles not in (reactant, product):
                    continue

            if frequency > 10:
                processed_lines.append((frequency, reactant, product))

    if not processed_lines:
        print(f"提示: 文件 {filepath} 中没有符合条件的反应")
        return

    # 创建反应数据DataFrame
    reaction_data = pd.DataFrame(processed_lines, columns=['Frequency', 'Reactant', 'Product'])

    # 构建反应网络
    for _, row in reaction_data.iterrows():
        reactant = row['Reactant']
        product = row['Product']
        G.add_node(reactant)
        G.add_node(product)
        G.add_edge(reactant, product, frequency=row['Frequency'])

    # 计算分子属性
    intermediates = list(set(reaction_data['Reactant']) | set(reaction_data['Product']))
    for intermediate in intermediates:
        mol = Chem.MolFromSmiles(intermediate)
        if mol:
            try:
                formula = Chem.rdMolDescriptors.CalcMolFormula(mol)
                intermediate_formulae[intermediate] = formula
                mol_weight = Descriptors.MolWt(mol)
                node_colors[intermediate] = get_color_by_weight(mol_weight)
            except:
                intermediate_formulae[intermediate] = ""
                node_colors[intermediate] = "lightgray"
        else:
            intermediate_formulae[intermediate] = ""
            node_colors[intermediate] = "lightgray"

    # 创建可视化网络
    net = Network(notebook=False, directed=True, height="800px", width="100%")
    net.barnes_hut(
        gravity=-2000,
        central_gravity=0.3,
        spring_length=200,
        spring_strength=0.05,
        damping=0.09,
        overlap=0
    )

    # 添加节点（固定大小和颜色逻辑）
    for intermediate in intermediates:
        formula = intermediate_formulae.get(intermediate, '')
        label = f"{formula}\n{intermediate}" if formula else intermediate
        net.add_node(
            intermediate,
            title=label,
            label=formula or intermediate[:15],
            color=node_colors.get(intermediate, "lightblue"),
            size=20  # 可根据需要调整固定大小
        )

    # 添加边（固定线宽逻辑）
    for u, v, d in G.edges(data=True):
        frequency = d['frequency']
        line_width = 1.0 + (frequency // 100) * 0.5  # 简单频率相关线宽
        net.add_edge(u, v, title=f"Frequency: {frequency}", width=line_width)

    # 生成唯一输出路径
    base_dir = os.path.dirname(filepath)
    filename = os.path.splitext(os.path.basename(filepath))[0]
    output_file = os.path.join(base_dir, f"{filename}_reaction_network.html")
    
    try:
        net.show(output_file)
        print(f"成功生成网络图: {os.path.abspath(output_file)}")
        
        # 尝试自动打开浏览器（Linux通用方式）
        subprocess.run(["xdg-open", output_file], check=False)
    except Exception as e:
        print(f"错误: 保存网络图 {output_file} 失败: {str(e)}")

    # 输出统计信息
    print(f"\n文件 {filepath} 分析结果:")
    print(f"节点数: {G.number_of_nodes()}")
    print(f"边数: {G.number_of_edges()}")
    print(f"最大频率: {reaction_data['Frequency'].max()}")
    print(f"最小频率: {reaction_data['Frequency'].min()}")
    print("节点列表:")
    for node in intermediates:
        print(f"- {node}")
    print("-" * 60)

def get_color_by_weight(weight):
    """根据分子量返回颜色"""
    if weight < 50:
        return "#FFCCCB"  # 浅红色
    elif weight < 100:
        return "#FFD700"  # 金色
    elif weight < 150:
        return "#90EE90"  # 浅绿色
    elif weight < 200:
        return "#ADD8E6"  # 浅蓝色
    else:
        return "#DDA0DD"  # 梅红色

if __name__ == "__main__":
    # 配置参数（可根据需要修改）
    TARGET_SMILES = "C"  # 目标筛选SMILES（设为None则不筛选）
    ROOT_DIR = "."       # 要搜索的根目录（默认当前目录）

    # 获取所有反应文件
    reaction_files = get_reaction_files(ROOT_DIR)
    if not reaction_files:
        print("错误: 当前目录及子目录中未找到任何.reaction文件")
        exit(1)

    # 处理每个文件
    for idx, file in enumerate(reaction_files, 1):
        print(f"\n正在处理文件 [{idx}/{len(reaction_files)}]: {file}")
        process_reaction_file(file, TARGET_SMILES)

    print("\n所有文件处理完成！")